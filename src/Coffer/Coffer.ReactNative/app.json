{
  "expo": {
    "name": "Coffer.ReactNative",
    "slug": "coffer",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "com.gelomelo.coffer",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.gelomelo.coffer",
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "com.gelomelo.coffer"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android_icon_foreground.png",
        "backgroundImage": "./assets/images/android_icon_background.png",
        "monochromeImage": "./assets/images/android_icon_monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash_icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-asset",
        {
          "assets": [
            "./assets/images/android_icon_foreground.png",
            "./assets/images/icon.png"
          ]
        }
      ],
      "expo-font",
      "react-native-navigation-mode"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "007245ec-3e87-420e-87da-743a5be7a593"
      }
    },
    "owner": "gelomelo"
  }
}
